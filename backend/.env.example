# backend/.env.example
# Copy this file to backend/.env and fill in your values.
#
# Required variables are marked with [REQUIRED].
# All others have sensible defaults for development.

# ─── Stellar Network [REQUIRED] ────────────────────────────────────────────────
# Must be "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Stellar Horizon API base URL [REQUIRED]
HORIZON_URL=https://horizon-testnet.stellar.org

# ─── Security [REQUIRED] ──────────────────────────────────────────────────────
# Secret key for SEP-0010 JWT token signing (min 32 chars)
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of CORS-allowed origins [REQUIRED for production]
# Format: scheme://host[:port] (no trailing slash, no wildcards)
# Defaults to http://localhost:3000 if unset
ALLOWED_ORIGINS=http://localhost:3000

# ─── Server ───────────────────────────────────────────────────────────────────
# HTTP port (default: 4000)
PORT=4000

# Environment: "development", "test", or "production" (default: development)
NODE_ENV=development

# Log level: "trace", "debug", "info", "warn", "error", "fatal" (default: info)
LOG_LEVEL=info

# ─── Error Tracking (optional) ────────────────────────────────────────────────
# Sentry DSN for error monitoring. Disabled if unset.
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/1234567

# ─── Federation (SEP-0002) ───────────────────────────────────────────────────
# Domain used in .well-known/stellar.toml discovery
# Falls back to DOMAIN, HOME_DOMAIN, or the request Host header
# FEDERATION_DOMAIN=stellarfinchippay.io

# Override the federation server URL (defaults to https://<FEDERATION_DOMAIN>/federation)
# FEDERATION_SERVER_URL=https://finchippay.io/federation

# Protocol override for federation server URL ("http" or "https")
# Auto-detected from domain unless explicitly set
# FEDERATION_SERVER_PROTOCOL=https

# Home domain for SEP-0010 challenge signing (default: localhost:4000)
# HOME_DOMAIN=finchippay.io

# Additional federation domains (comma-separated)
# FEDERATION_DOMAINS=finchippay.io,stellarfinchippay.io

# ─── Turrets (Scheduled Transactions) ─────────────────────────────────────────
# Port for the Turrets side-server (default: 4100)
# TURRETS_PORT=4100

# Interval in ms between txFunction evaluation polls (default: 30000)
TURRETS_EVALUATION_INTERVAL_MS=30000

# ─── Stellar Account (SEP-0010) ───────────────────────────────────────────────
# Stellar secret key for challenge signing. Auto-generated on startup if unset.
# SERVER_PRIVATE_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── AI Payment Parsing (optional) ────────────────────────────────────────────
# Anthropic API key for the AI payment assistant feature.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
